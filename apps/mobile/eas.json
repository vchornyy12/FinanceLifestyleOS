{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "cache": {
        "key": "preview-v1",
        "paths": [
          "apps/mobile/node_modules/.cache",
          "~/.gradle/caches",
          "~/.gradle/wrapper"
        ]
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
