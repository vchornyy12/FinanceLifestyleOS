# Supabase — copy this file to .env.local and fill in your project values.
# Find these in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-or-publishable-key>

# Public URL of this app (used for OAuth redirects, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic — for receipt OCR via Claude 3.5 Sonnet vision
ANTHROPIC_API_KEY=

# Supabase service role key — server-side only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=
